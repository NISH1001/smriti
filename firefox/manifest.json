{
  "manifest_version": 2,
  "name": "Smriti",
  "version": "0.1.0",
  "description": "Highlight snippets as you read, then send them to Smriti in bulk.",
  "browser_specific_settings": {
    "gecko": {
      "id": "smriti@nishparadox",
      "strict_min_version": "121.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/smriti.svg",
    "96": "icons/smriti.svg"
  }
}
